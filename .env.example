DATABASE_URL="postgresql://username:password@localhost:5432/chatapp"

REDIS_URL = "redis://localhost:6379"

MAX_CACHE_MESSAGES = 50 // Maximum number of messages to cache in Redis
TTL_SECONDS = 3600 // 1 hour in seconds

JWT_SECRET = 'your_jwt_secret_key_here'
JWT_EXPIRES_IN = '7d' // JWT token expiration time (e.g., '7d' for 7 days, '24h' for 24 hours)

CLIENT_URL = '*' // Allowed origins for CORS (e.g., 'http://localhost:3000' or '*' for all origins)

PORT = 3000 